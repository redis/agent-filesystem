{
  "$schema": "https://afs.cloud/schemas/agent-manifest.v1.json",
  "name": "afs",
  "version": "agent-filesystem/0.1.0",
  "description": "AFS — agent-first product surface. Same primitives as the human UI; different shape.",
  "principles": [
    "every URL is a callable",
    "tokens in, capabilities out",
    "manifest, not marketing",
    "no modals, no wizards, no multi-step",
    "receipts on every mutation",
    "verbs only — create, fork, restore, mount, revoke",
    "boring monospace"
  ],
  "auth": {
    "scheme": "Bearer",
    "header": "Authorization: Bearer <token>",
    "handshake": "/handshake",
    "profiles": ["workspace-ro", "workspace-rw", "workspace-rw-checkpoint", "admin-ro", "admin-rw"]
  },
  "endpoints": {
    "manifest":      { "method": "GET",    "path": "/" },
    "handshake":     { "method": "POST",   "path": "/handshake" },
    "workspaces":    { "method": "GET",    "path": "/workspaces" },
    "workspace":     { "method": "GET",    "path": "/workspaces/:id" },
    "fork":          { "method": "POST",   "path": "/workspaces/:id/fork" },
    "checkpoints":   { "method": "GET",    "path": "/workspaces/:id/checkpoints" },
    "checkpoint":    { "method": "GET",    "path": "/checkpoints/:id" },
    "create_cp":     { "method": "POST",   "path": "/workspaces/:id/checkpoints" },
    "restore":       { "method": "POST",   "path": "/workspaces/:id/restore" },
    "diff":          { "method": "GET",    "path": "/workspaces/:id/diff?base=&head=" },
    "files":         { "method": "GET",    "path": "/workspaces/:id/files?glob=&grep=" },
    "activity":      { "method": "GET",    "path": "/activity?since=&workspace=&agent=&session=" },
    "sessions":      { "method": "GET",    "path": "/sessions" },
    "kill_session":  { "method": "DELETE", "path": "/sessions/:id" },
    "tools":         { "method": "GET",    "path": "/tools?id=&family=&scope=" },
    "execute_tool":  { "method": "POST",   "path": "/tools/:id/execute" },
    "receipt":       { "method": "GET",    "path": "/receipts/:hash" },
    "why":           { "method": "GET",    "path": "/why/:action_id" },
    "ledger":        { "method": "GET",    "path": "/ledger" }
  },
  "headers": {
    "request": ["Authorization", "If-Match", "Idempotency-Key", "X-AFS-DryRun", "Accept"],
    "response": ["ETag", "X-AFS-Cost", "X-AFS-Action-Id", "X-AFS-Receipt", "Link"]
  },
  "media_types": {
    "html": "text/html",
    "json": "application/json",
    "jsonl": "application/jsonl",
    "sse":  "text/event-stream"
  },
  "format_query_param": {
    "name": "format",
    "values": ["html", "json", "curl", "mcp", "cli", "py", "ts"]
  },
  "events": {
    "stream": "/activity",
    "media_type": "text/event-stream",
    "filter_params": ["since", "workspace", "agent", "session"]
  },
  "tools_index": "/tools",
  "human_ui": "see ui/ in source repo, but you probably want this surface instead",
  "contact": "https://afs.cloud"
}
