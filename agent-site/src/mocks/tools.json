{
  "items": [
    {
      "id": "workspace_list",
      "name": "workspace_list",
      "surface": "mcp",
      "family": "workspace",
      "scope": "read",
      "profile": "workspace-ro",
      "description": "List all workspaces visible to the current token. Mirrors GET /workspaces.",
      "params": [],
      "returns": "{ items: Workspace[], etag: string, count: number, dirty_count: number }",
      "example": {
        "args": {},
        "result": { "items": ["...3 workspaces..."], "count": 3, "dirty_count": 2 }
      }
    },
    {
      "id": "workspace_create",
      "name": "workspace_create",
      "surface": "mcp",
      "family": "workspace",
      "scope": "write",
      "profile": "workspace-rw",
      "description": "Create a new empty workspace.",
      "params": [
        { "name": "name", "type": "string", "required": true, "description": "Globally unique workspace id." },
        { "name": "database_id", "type": "string", "required": false, "description": "Defaults to the token's bound database." }
      ],
      "returns": "Workspace",
      "example": {
        "args": { "name": "scratch-2026-05" },
        "result": { "id": "scratch-2026-05", "draft_state": "clean", "file_count": 0 }
      }
    },
    {
      "id": "workspace_fork",
      "name": "workspace_fork",
      "surface": "mcp",
      "family": "workspace",
      "scope": "write",
      "profile": "workspace-rw",
      "description": "Fork a workspace into a new parallel timeline. Optional from_checkpoint to fork from a specific point.",
      "params": [
        { "name": "source", "type": "string", "required": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "from_checkpoint", "type": "string", "required": false }
      ],
      "returns": "Workspace",
      "example": {
        "args": { "source": "payments-portal", "name": "payments-portal-experiment" },
        "result": { "id": "payments-portal-experiment", "draft_state": "clean" }
      }
    },
    {
      "id": "checkpoint_create",
      "name": "checkpoint_create",
      "surface": "mcp",
      "family": "checkpoint",
      "scope": "write",
      "profile": "workspace-rw-checkpoint",
      "description": "Save the live workspace state as an immutable checkpoint. Idempotent on (workspace, name).",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "note", "type": "string", "required": false }
      ],
      "returns": "Checkpoint",
      "example": {
        "args": { "workspace_id": "payments-portal", "name": "before-stripe-migration" },
        "result": { "id": "cp-pp-011", "manifest_hash": "sha256:a3f4..." }
      }
    },
    {
      "id": "checkpoint_restore",
      "name": "checkpoint_restore",
      "surface": "mcp",
      "family": "checkpoint",
      "scope": "write",
      "profile": "workspace-rw-checkpoint",
      "description": "Restore a workspace to a saved checkpoint. Auto-creates a safety checkpoint of the current state if dirty.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "checkpoint_id", "type": "string", "required": true }
      ],
      "returns": "{ restored: true, safety_checkpoint_id: string|null }",
      "example": {
        "args": { "workspace_id": "payments-portal", "checkpoint_id": "cp-pp-010" },
        "result": { "restored": true, "safety_checkpoint_id": "cp-pp-safety-2026-05-01" }
      }
    },
    {
      "id": "file_read",
      "name": "file_read",
      "surface": "mcp",
      "family": "file",
      "scope": "read",
      "profile": "workspace-ro",
      "description": "Read a file's contents from a workspace at a given ref.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "path", "type": "string", "required": true },
        { "name": "ref", "type": "string", "required": false, "description": "checkpoint:<id> | working-copy (default)" }
      ],
      "returns": "{ content: string, hash: string, bytes: number }",
      "example": {
        "args": { "workspace_id": "payments-portal", "path": "src/api/charges.ts" },
        "result": { "content": "export async function charge(...)", "bytes": 4112, "hash": "sha256:c1a2..." }
      }
    },
    {
      "id": "file_write",
      "name": "file_write",
      "surface": "mcp",
      "family": "file",
      "scope": "write",
      "profile": "workspace-rw",
      "description": "Write a file's full contents. Use file_replace for surgical edits.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "path", "type": "string", "required": true },
        { "name": "content", "type": "string", "required": true }
      ],
      "returns": "Receipt",
      "example": {
        "args": { "workspace_id": "scratch-2026-05", "path": "notes/draft.md", "content": "# notes\n" },
        "result": { "hash": "sha256:7d3f...", "bytes_delta": 9 }
      }
    },
    {
      "id": "file_grep",
      "name": "file_grep",
      "surface": "mcp",
      "family": "file",
      "scope": "read",
      "profile": "workspace-ro",
      "description": "Search file contents in a workspace. Literal or regex.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "pattern", "type": "string", "required": true },
        { "name": "ignore_case", "type": "boolean", "required": false },
        { "name": "glob", "type": "string", "required": false }
      ],
      "returns": "{ matches: { path: string, line: number, text: string }[] }",
      "example": {
        "args": { "workspace_id": "payments-portal", "pattern": "stripe.charges.create" },
        "result": { "matches": [{ "path": "src/api/charges.ts", "line": 42, "text": "  await stripe.charges.create(..)" }] }
      }
    },
    {
      "id": "file_glob",
      "name": "file_glob",
      "surface": "mcp",
      "family": "file",
      "scope": "read",
      "profile": "workspace-ro",
      "description": "List files matching a glob pattern.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "pattern", "type": "string", "required": true }
      ],
      "returns": "{ paths: string[] }",
      "example": {
        "args": { "workspace_id": "payments-portal", "pattern": "**/*.test.ts" },
        "result": { "paths": ["tests/charges.test.ts", "tests/refunds.test.ts"] }
      }
    },
    {
      "id": "file_replace",
      "name": "file_replace",
      "surface": "mcp",
      "family": "file",
      "scope": "write",
      "profile": "workspace-rw",
      "description": "Surgical edit. Replace exact-match text. Fails if old_text is not unique.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "path", "type": "string", "required": true },
        { "name": "old_text", "type": "string", "required": true },
        { "name": "new_text", "type": "string", "required": true }
      ],
      "returns": "Receipt",
      "example": {
        "args": { "workspace_id": "payments-portal", "path": "src/api/charges.ts", "old_text": "v8", "new_text": "v9" },
        "result": { "hash": "sha256:eedd..." }
      }
    },
    {
      "id": "file_patch",
      "name": "file_patch",
      "surface": "mcp",
      "family": "file",
      "scope": "write",
      "profile": "workspace-rw",
      "description": "Apply a unified diff hunk to a file. Atomic.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": true },
        { "name": "path", "type": "string", "required": true },
        { "name": "patch", "type": "string", "required": true }
      ],
      "returns": "Receipt"
    },
    {
      "id": "afs_status",
      "name": "afs_status",
      "surface": "mcp",
      "family": "admin",
      "scope": "read",
      "profile": "workspace-ro",
      "description": "Probe. Returns server identity, version, current capability, current workspace.",
      "params": [],
      "returns": "{ version: string, capability: Capability, current_workspace: string|null }"
    },
    {
      "id": "mcp_token_issue",
      "name": "mcp_token_issue",
      "surface": "mcp",
      "family": "admin",
      "scope": "admin",
      "profile": "admin-rw",
      "description": "Issue a new MCP access token scoped to a workspace and profile.",
      "params": [
        { "name": "workspace_id", "type": "string", "required": false },
        { "name": "profile", "type": "string", "required": true },
        { "name": "ttl_seconds", "type": "number", "required": false }
      ],
      "returns": "{ token: string, token_id: string, expires_at: string }"
    },
    {
      "id": "mcp_token_revoke",
      "name": "mcp_token_revoke",
      "surface": "mcp",
      "family": "admin",
      "scope": "admin",
      "profile": "admin-rw",
      "description": "Revoke an MCP access token.",
      "params": [
        { "name": "token_id", "type": "string", "required": true }
      ],
      "returns": "{ revoked: true }"
    }
  ]
}
